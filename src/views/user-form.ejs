<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= user ? 'Редактирование' : 'Добавление' %> пользователя - <%= appName %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <header class="bg-slate-800 text-white px-8 py-4">
        <h1 class="text-xl">
            <%= user ? 'Редактирование' : 'Добавление' %> пользователя
        </h1>
    </header>
    <main class="max-w-md mx-auto mt-8 px-4">
        <div class="bg-white rounded-lg shadow p-6">
            <% if (error) { %>
                <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
                    <%= error %>
                </div>
                <% } %>
                    <form method="POST" action="/admin/users<%= user ? '/' + user.id : '' %>">
                        <div class="mb-4">
                            <label class="block text-gray-700 font-medium mb-2">Имя пользователя</label>
                            <input type="text" name="username" value="<%= user ? user.username : '' %>" required
                                class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-green-500">
                        </div>
                        <% if (user && user.username==='admin' ) { %>
                            <div class="mb-4">
                                <label class="block text-gray-700 font-medium mb-2">Новый пароль <span
                                        class="text-gray-400 text-sm">(оставьте пустым, чтобы не менять)</span></label>
                                <input type="password" name="password"
                                    class="w-full px-4 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-green-500">
                            </div>
                            <% } %>
                                <div class="mb-6">
                                    <label class="flex items-center gap-2">
                                        <input type="checkbox" name="is_active" id="is_active" value="1" <%=(!user ||
                                            user.is_active) ? 'checked' : '' %> class="w-4 h-4">
                                        <span>Пользователь активен</span>
                                    </label>
                                </div>
                                <div class="flex gap-4">
                                    <button type="submit"
                                        class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700">
                                        <%= user ? 'Сохранить' : 'Создать' %>
                                    </button>
                                    <a href="/admin"
                                        class="bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600">Отмена</a>
                                </div>
                    </form>
        </div>
    </main>
</body>

</html>