<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Серверы пользователя - <%= appName %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">
    <header class="bg-slate-800 text-white px-8 py-4">
        <h1 class="text-xl">Серверы пользователя: <%= user.username %>
        </h1>
    </header>
    <main class="max-w-2xl mx-auto mt-8 px-4">
        <div class="bg-white rounded-lg shadow p-6">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Ссылка подписки</h2>
            <div class="flex items-center gap-3 mb-4">
                <a href="/join/<%= user.id %>#Подписка_<%= user.username %>" target="_blank" class="block bg-blue-50 p-3 rounded text-lg break-all hover:bg-blue-100 text-blue-600"><%= user.id %></a>
                <a href="/join/<%= user.id %>/qr" target="_blank" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">QR код</a>
            </div>

            <form method="POST" action="/admin/users/<%= user.id %>/servers">
                <div class="mb-4 pb-4 border-b">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" id="select-all" class="w-4 h-4">
                        <span>Выбрать все серверы</span>
                    </label>
                </div>

                <% if (servers.length===0) { %>
                    <p class="text-gray-500">Нет доступных серверов. <a href="/admin/servers/new"
                            class="text-green-600 hover:underline">Создайте сервер</a>.</p>
                    <% } else { %>
                        <% const assignedIdsStr = assignedIds.map(String); %>
                        <div class="space-y-3 mb-6">
                            <% servers.forEach(function(server) { %>
                                <div class="p-3 border rounded hover:bg-gray-50">
                                    <div class="flex items-center gap-3 mb-2">
                                        <input type="checkbox" name="servers" value="<%= String(server.id) %>"
                                            class="w-4 h-4" <%= assignedIdsStr.includes(String(server.id)) ? 'checked' : '' %>>
                                        <div>
                                            <div class="font-medium">
                                                <%= server.name %>
                                            </div>
                                            <div class="text-sm text-gray-500">
                                                <%= server.protocol ? server.protocol.toUpperCase() : '' %> | <%= server.host %>:<%= server.port %>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="ml-7">
                                        <label class="block text-sm text-gray-600 mb-1">UUID для этого сервера:</label>
                                        <input type="text" name="uuids[<%= server.id %>]" value="<%= uuidMap[server.id] || '' %>"
                                            placeholder="Оставьте пустым для автогенерации"
                                            class="w-full px-3 py-1.5 border rounded text-sm font-mono">
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } %>

                            <div class="flex gap-4">
                                <button type="submit"
                                    class="bg-green-600 text-white px-6 py-2 rounded hover:bg-green-700">Сохранить</button>
                                <a href="/admin"
                                    class="bg-gray-500 text-white px-6 py-2 rounded hover:bg-gray-600">Отмена</a>
                            </div>
            </form>
        </div>
    </main>
    <script>
        document.getElementById('select-all').addEventListener('change', function () {
            const checkboxes = document.querySelectorAll('input[name="servers"]');
            checkboxes.forEach(function (cb) { cb.checked = document.getElementById('select-all').checked; });
        });
    </script>
</body>

</html>